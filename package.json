{
  "name": "read-aloud-easy",
  "private": true,
  "version": "0.1.0",
  "description": "Dyslexia-friendly web reader with speed control, furigana, and difficulty highlighting",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint src --ext .ts",
    "test": "tsx tests/speed-pitch.test.ts && tsx tests/bookmark.test.ts",
    "test:run": "tsx tests/speed-pitch.test.ts && tsx tests/bookmark.test.ts",
    "package": "npm run build && node scripts/package.mjs"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.268",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "tsx": "^4.22.1",
    "typescript": "^5.0.0",
    "vite": "^5.0.0"
  }
}
